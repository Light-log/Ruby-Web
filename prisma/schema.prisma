// ─────────────────────────────────────────────────────────────────────────────
// Omnichannel SaaS Platform – Prisma Schema
// 7 layers: Multitenant Core · Channel Hub · AI Router · Bot Engine
//            Canonical Message · Live Hub · Script Runtime
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum ChannelType {
  WEB_WIDGET
  WHATSAPP
  FACEBOOK_MESSENGER
  INSTAGRAM
  TIKTOK
  LINKEDIN
  EMAIL
}

enum AIProvider {
  OPENAI
  GEMINI
}

enum AIUseCase {
  CLASSIFICATION
  GENERATION
  EXTRACTION
  SUMMARIZATION
  SUGGESTION
}

enum FlowNodeType {
  MESSAGE
  QUESTION
  BUTTONS
  CAROUSEL
  FORM
  CONDITION
  HTTP_REQUEST
  SCRIPT
  AI_GENERATE
  HANDOFF
  END
}

enum CanonicalBlockType {
  TEXT
  BUTTONS
  QUICK_REPLIES
  CARD
  CARD_LIST
  FORM
  IMAGE
  VIDEO
  FILE
  LOCATION
  LIST_PICKER
}

enum ConversationStatus {
  BOT
  WAITING
  LIVE
  RESOLVED
  ABANDONED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ScriptLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SUSPEND
  ACTIVATE
  PUBLISH
  EXECUTE
}

// ─── LAYER 1: MULTITENANT CORE ────────────────────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  interval    String   @default("monthly")

  maxCompanies      Int @default(1)
  maxUsers          Int @default(5)
  maxAgents         Int @default(2)
  maxChannels       Int @default(2)
  maxBots           Int @default(1)
  maxConversations  Int @default(1000)
  maxMessages       Int @default(10000)
  maxScripts        Int @default(5)
  maxStorageGb      Int @default(1)
  aiCallsPerMonth   Int @default(500)

  hasLiveChat     Boolean @default(true)
  hasAI           Boolean @default(true)
  hasCustomCode   Boolean @default(false)
  hasWebhooks     Boolean @default(true)
  hasAnalytics    Boolean @default(true)
  hasWhiteLabel   Boolean @default(false)
  hasMultiChannel Boolean @default(false)

  companies Company[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id       String        @id @default(cuid())
  name     String
  slug     String        @unique
  status   CompanyStatus @default(TRIAL)
  planId   String
  plan     Plan          @relation(fields: [planId], references: [id])

  logoUrl      String?
  primaryColor String?
  domain       String?

  customMaxUsers    Int?
  customMaxAgents   Int?
  customMaxChannels Int?
  customAiCalls     Int?

  currentMonthConversations Int      @default(0)
  currentMonthMessages      Int      @default(0)
  currentMonthAiCalls       Int      @default(0)
  usageResetAt              DateTime @default(now())

  memberships     Membership[]
  channels        Channel[]
  aiConfigs       AIConfig[]
  flows           Flow[]
  canonicalBlocks CanonicalBlock[]
  conversations   Conversation[]
  scripts         ScriptTemplate[]
  httpCredentials HttpCredential[]
  webhooks        Webhook[]
  featureFlags    CompanyFeatureFlag[]
  auditLogs       AuditLog[]
  knowledgeBases  KnowledgeBase[]
  intents         Intent[]
  queues          Queue[]
  liveSchedule    LiveSchedule?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String?
  avatarUrl    String?
  isSuperAdmin Boolean @default(false)
  isActive     Boolean @default(true)

  memberships   Membership[]
  sessions      Session[]
  assignedConvs ConversationAssignment[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(AGENT)
  isActive  Boolean  @default(true)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
}

model AuditLog {
  id        String      @id @default(cuid())
  companyId String?
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  metadata  Json?

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model CompanyFeatureFlag {
  id        String  @id @default(cuid())
  companyId String
  flag      String
  enabled   Boolean @default(false)
  metadata  Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, flag])
}

// ─── LAYER 2: CHANNEL HUB ─────────────────────────────────────────────────────

model Channel {
  id        String      @id @default(cuid())
  companyId String
  type      ChannelType
  name      String
  isActive  Boolean     @default(false)
  config    Json
  metadata  Json?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type])
  @@index([companyId])
}

// ─── LAYER 3: AI PROVIDER ROUTER ──────────────────────────────────────────────

model AIConfig {
  id        String     @id @default(cuid())
  companyId String     @unique
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  primaryProvider  AIProvider
  primaryModel     String
  primaryApiKeyRef String

  fallbackProvider  AIProvider?
  fallbackModel     String?
  fallbackApiKeyRef String?

  classificationModel String?
  generationModel     String?
  extractionModel     String?
  summarizationModel  String?
  suggestionModel     String?

  systemPrompt  String?  @db.Text
  tone          String?
  language      String   @default("es")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(1024)
  thinkingLevel String?
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIVaultKey {
  id           String     @id @default(cuid())
  ref          String     @unique
  provider     AIProvider
  encryptedKey String
  iv           String
  isActive     Boolean    @default(true)
  label        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── LAYER 4: BOT / FLOW ENGINE ───────────────────────────────────────────────

model Flow {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(false)
  version     Int     @default(1)

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nodes     FlowNode[]
  versions  FlowVersion[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
}

model FlowVersion {
  id       String @id @default(cuid())
  flowId   String
  version  Int
  snapshot Json
  notes    String?

  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([flowId, version])
}

model FlowNode {
  id       String       @id @default(cuid())
  flowId   String
  type     FlowNodeType
  label    String?
  config   Json
  position Json
  edges    Json

  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([flowId])
}

// ─── LAYER 5: CANONICAL MESSAGE ENGINE ────────────────────────────────────────

model CanonicalBlock {
  id        String             @id @default(cuid())
  companyId String
  name      String
  type      CanonicalBlockType
  content   Json
  tags      String[]
  isGlobal  Boolean            @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
}

model RendererRule {
  id         String             @id @default(cuid())
  companyId  String?
  channel    ChannelType
  blockType  CanonicalBlockType
  fallbackTo CanonicalBlockType?
  config     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, channel, blockType])
}

// ─── LAYER 6: LIVE CONVERSATION HUB ──────────────────────────────────────────

model Conversation {
  id            String             @id @default(cuid())
  companyId     String
  channelId     String
  status        ConversationStatus @default(BOT)
  externalId    String?
  contactId     String?
  flowId        String?
  currentNodeId String?

  firstResponseAt DateTime?
  resolvedAt      DateTime?
  slaBreached     Boolean   @default(false)
  waitingSince    DateTime?

  botPaused   Boolean   @default(false)
  botPausedAt DateTime?
  botResumeAt DateTime?

  metadata Json?

  company     Company                  @relation(fields: [companyId], references: [id])
  channel     Channel                  @relation(fields: [channelId], references: [id])
  contact     Contact?                 @relation(fields: [contactId], references: [id])
  messages    Message[]
  assignments ConversationAssignment[]
  notes       ConversationNote[]
  tags        ConversationTag[]
  transfers   ConversationTransfer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, channelId])
  @@index([contactId])
}

model Contact {
  id        String  @id @default(cuid())
  companyId String
  name      String?
  email     String?
  phone     String?
  language  String?
  timezone  String?
  metadata  Json?

  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  channel        ChannelType
  content        Json
  rawPayload     Json?
  isBot          Boolean          @default(false)
  agentId        String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model ConversationAssignment {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  assignedAt     DateTime  @default(now())
  unassignedAt   DateTime?
  isActive       Boolean   @default(true)

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model ConversationNote {
  id             String @id @default(cuid())
  conversationId String
  authorId       String
  content        String @db.Text

  conversation Conversation @relation(fields: [conversationId], references: [id])
  createdAt    DateTime     @default(now())
}

model ConversationTag {
  id             String @id @default(cuid())
  conversationId String
  tag            String

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, tag])
}

model ConversationTransfer {
  id             String  @id @default(cuid())
  conversationId String
  fromAgentId    String?
  toAgentId      String?
  fromQueue      String?
  toQueue        String?
  reason         String?

  conversation Conversation @relation(fields: [conversationId], references: [id])
  createdAt    DateTime     @default(now())
}

model Queue {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String?
  slaMinutes  Int     @default(30)
  isDefault   Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model LiveSchedule {
  id        String  @id @default(cuid())
  companyId String  @unique
  timezone  String  @default("America/Caracas")
  schedule  Json
  message   String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── LAYER 7: AUTOMATION + SAFE SCRIPT RUNTIME ────────────────────────────────

model ScriptTemplate {
  id          String         @id @default(cuid())
  companyId   String
  name        String
  description String?
  language    ScriptLanguage @default(JAVASCRIPT)
  isActive    Boolean        @default(true)

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions ScriptVersion[]
  bindings ScriptBinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model ScriptVersion {
  id          String  @id @default(cuid())
  scriptId    String
  version     Int
  code        String  @db.Text
  notes       String?
  isPublished Boolean @default(false)

  script    ScriptTemplate @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([scriptId, version])
}

model ScriptBinding {
  id       String @id @default(cuid())
  scriptId String
  name     String
  type     String
  value    String

  script ScriptTemplate @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, name])
}

model ScriptExecution {
  id          String   @id @default(cuid())
  scriptId    String
  version     Int
  triggeredBy String?
  input       Json?
  output      Json?
  logs        String?  @db.Text
  durationMs  Int?
  exitCode    Int?
  error       String?

  createdAt DateTime @default(now())

  @@index([scriptId, createdAt])
}

model HttpCredential {
  id        String @id @default(cuid())
  companyId String
  name      String
  baseUrl   String
  authType  String
  config    Json

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model AllowedDomain {
  id        String  @id @default(cuid())
  domain    String  @unique
  isGlobal  Boolean @default(false)
  companyId String?

  createdAt DateTime @default(now())
}

model Webhook {
  id        String   @id @default(cuid())
  companyId String
  name      String
  url       String
  events    String[]
  secret    String?
  isActive  Boolean  @default(true)
  headers   Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ─── NLU LAYER (Intent & Knowledge) ──────────────────────────────────────────

model Intent {
  id        String   @id @default(cuid())
  companyId String
  name      String
  examples  String[]
  action    String?
  metadata  Json?
  isActive  Boolean  @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model KnowledgeBase {
  id        String  @id @default(cuid())
  companyId String
  name      String
  type      String
  content   Json
  embedding Json?
  isActive  Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
}
