# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/omnichannel_platform"

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="change-this-to-a-32+-character-random-string"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Email (Contact form) ─────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="no-reply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="no-reply@example.com"
CONTACT_TO="hello@example.com"

# ─── AI Providers (stored in vault in production, env only for dev) ───────────
# These are only used directly in development; in production use AIVaultKey table
OPENAI_API_KEY_DEV="sk-..."
GEMINI_API_KEY_DEV="AIza..."

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN="my-verify-token"
# Per-company phone number IDs and access tokens are stored in Channel.config (encrypted)

# ─── Meta (Messenger / Instagram) ────────────────────────────────────────────
MESSENGER_VERIFY_TOKEN="my-verify-token"
# Per-company page IDs and tokens stored in Channel.config

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="omnichannel"

# ─── Telemetry ────────────────────────────────────────────────────────────────
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
