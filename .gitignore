# ------------------------------------
# Dependencias (Nunca subir esto)
# ------------------------------------
/node_modules
/.pnp
.pnp.js

# ------------------------------------
# Next.js - Archivos de compilación
# ------------------------------------
/.next/
/out/
/build

# ------------------------------------
# Producción y Despliegue
# ------------------------------------
# Generado por Vercel CLI (si lo usas)
.vercel

# ------------------------------------
# TypeScript
# ------------------------------------
# Archivo de declaración generado automáticamente por Next.js
next-env.d.ts
# Cache de compilación incremental de TS
*.tsbuildinfo

# ------------------------------------
# Variables de Entorno (SEGURIDAD CRÍTICA)
# ------------------------------------
# Ignora todos los archivos .env locales para no filtrar claves secretas
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# EXCEPCIÓN: Si tienes un archivo de ejemplo, permite subirlo:
!0.env.example

# ------------------------------------
# Logs y Debugging
# ------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------
# Sistema Operativo (Basura del sistema)
# ------------------------------------
.DS_Store
Thumbs.db
*.pem

# ------------------------------------
# IDE / Editores (Opcional)
# ------------------------------------
/.idea
.vscode/
*.swp